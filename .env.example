# ─── Copy to .env and set production values ───────────────────────────────────
# cp .env.example .env

# ─── PostgreSQL (used by docker-compose `postgres` service) ────────────────────
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ecommerce

# ─── Public URLs (browser + CORS; use your real domain in production) ───────────
# Examples with default compose port mapping:
PUBLIC_API_URL=http://localhost:5000
PUBLIC_DASHBOARD_URL=http://localhost:3000
PUBLIC_STORE_URL=http://localhost:3001

# ─── API (Express) ─────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-long-random-session-secret
CUSTOMER_JWT_SECRET=change-me-long-random-jwt-secret
NODE_ENV=production

# AWS S3 (product images) — required for image uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Optional email (module exists; mount routes if enabled)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# ─── Next.js build args (baked into client bundle at image build time) ───────────
# Must match PUBLIC_* URLs above (include /api/v1 path for API root).
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
